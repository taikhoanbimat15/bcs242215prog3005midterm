@model EventCategory_BCS242215

@{
    ViewData["Title"] = "Xóa loại sự kiện";
    var deleteBlocked = (bool)(ViewData["DeleteBlocked"] ?? false);
}

<h1 class="h3 mb-3">Xóa loại sự kiện</h1>

@if (deleteBlocked)
{
    <div class="alert alert-danger">Không được xóa loại sự kiện đang có sự kiện sử dụng.</div>
}

<div class="border rounded p-3 mb-3">
    <dl class="row mb-0">
        <dt class="col-sm-3">Tên loại</dt>
        <dd class="col-sm-9">@Model.Name</dd>
        <dt class="col-sm-3">Mô tả</dt>
        <dd class="col-sm-9">@Model.Description</dd>
        <dt class="col-sm-3">Số sự kiện</dt>
        <dd class="col-sm-9">@Model.Events.Count</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
</form>
