@model IEnumerable<EventCategory_BCS242215>

@{
    ViewData["Title"] = "Loại sự kiện";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 mb-0">Loại sự kiện</h1>
    <a asp-action="Create" class="btn btn-primary">Tạo loại</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Tên loại</th>
                <th>Mô tả</th>
                <th>Số sự kiện</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td class="fw-semibold">@category.Name</td>
                    <td>@category.Description</td>
                    <td>@category.Events.Count</td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
