@model Event_BCS242215

@{
    ViewData["Title"] = "Chi tiết sự kiện";
    var now = DateTime.Now;
    var status = Model.GetStatus(now);
    var images = Model.EventImages.OrderByDescending(image => image.IsThumbnail).ThenBy(image => image.Id).ToList();
}

@functions {
    private static string BadgeClass(string status)
    {
        return status switch
        {
            "Sắp diễn ra" => "text-bg-primary",
            "Đang diễn ra" => "text-bg-success",
            _ => "text-bg-secondary"
        };
    }
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        <span class="badge @BadgeClass(status)">@status</span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="AddImage" asp-route-eventId="@Model.Id" class="btn btn-primary">Thêm ảnh</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Sửa</a>
        <a asp-action="Index" class="btn btn-outline-dark">Danh sách</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="border rounded p-3 h-100">
            <dl class="row mb-0">
                <dt class="col-sm-4">Loại</dt>
                <dd class="col-sm-8">@Model.EventCategory?.Name</dd>
                <dt class="col-sm-4">Giá</dt>
                <dd class="col-sm-8">@Model.Price.ToString("N0")</dd>
                <dt class="col-sm-4">Địa điểm</dt>
                <dd class="col-sm-8">@Model.Location</dd>
                <dt class="col-sm-4">Bắt đầu</dt>
                <dd class="col-sm-8">@Model.StartDate.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt class="col-sm-4">Kết thúc</dt>
                <dd class="col-sm-8">@Model.EndDate.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt class="col-sm-4">Mô tả</dt>
                <dd class="col-sm-8">@Model.Description</dd>
            </dl>
        </div>
    </div>
    <div class="col-lg-7">
        @if (!images.Any())
        {
            <div class="alert alert-warning">Sự kiện chưa có ảnh.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var image in images)
                {
                    <div class="col-md-6">
                        <div class="border rounded p-2 h-100">
                            <img src="@image.ImageUrl" class="event-detail-image" alt="@Model.Name" />
                            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-2">
                                @if (image.IsThumbnail)
                                {
                                    <span class="badge text-bg-success">Ảnh đại diện</span>
                                }
                                else
                                {
                                    <form asp-action="SetThumbnail" method="post">
                                        <input type="hidden" name="eventId" value="@Model.Id" />
                                        <input type="hidden" name="imageId" value="@image.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Đặt đại diện</button>
                                    </form>
                                }
                                <form asp-action="DeleteImage" method="post">
                                    <input type="hidden" name="eventId" value="@Model.Id" />
                                    <input type="hidden" name="imageId" value="@image.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa ảnh</button>
                                </form>
                            </div>
                            <div class="small text-muted text-break mt-2">@image.ImageUrl</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
