@model EventManagement_BCS242215.ViewModels.EventImageFormViewModel_BCS242215

@{
    ViewData["Title"] = "Thêm ảnh";
}

<h1 class="h3 mb-3">Thêm ảnh cho @Model.EventName</h1>

<form asp-action="AddImage" method="post" class="row g-3">
    <input type="hidden" asp-for="EventId" />
    <input type="hidden" asp-for="EventName" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-10">
        <label asp-for="ImageUrl" class="form-label">Đường dẫn ảnh</label>
        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <div class="form-check mb-2">
            <input asp-for="IsThumbnail" class="form-check-input" />
            <label asp-for="IsThumbnail" class="form-check-label">Ảnh đại diện</label>
        </div>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Thêm ảnh</button>
        <a asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
