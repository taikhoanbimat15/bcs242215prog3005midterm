@model Event_BCS242215

@{
    ViewData["Title"] = "Xóa sự kiện";
    var deleteBlocked = (bool)(ViewData["DeleteBlocked"] ?? false);
}

<h1 class="h3 mb-3">Xóa sự kiện</h1>

@if (deleteBlocked)
{
    <div class="alert alert-danger">Không được xóa sự kiện đang diễn ra.</div>
}

<div class="border rounded p-3 mb-3">
    <dl class="row mb-0">
        <dt class="col-sm-3">Tên sự kiện</dt>
        <dd class="col-sm-9">@Model.Name</dd>
        <dt class="col-sm-3">Loại</dt>
        <dd class="col-sm-9">@Model.EventCategory?.Name</dd>
        <dt class="col-sm-3">Thời gian</dt>
        <dd class="col-sm-9">@Model.StartDate.ToString("dd/MM/yyyy HH:mm") - @Model.EndDate.ToString("dd/MM/yyyy HH:mm")</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Quay lại</a>
</form>
